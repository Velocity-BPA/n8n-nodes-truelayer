{
  "name": "n8n-nodes-truelayer",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for TrueLayer Open Banking API providing 19 resources and 100+ operations for payments, payouts, mandates, account data, identity verification, and merchant account management.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-truelayer.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-truelayer#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-truelayer/issues"
  },
  "main": "dist/nodes/TrueLayer/TrueLayer.node.js",
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "truelayer",
    "open-banking",
    "payments",
    "payouts",
    "psd2",
    "aisp",
    "pisp",
    "vrp",
    "mandates",
    "banking",
    "fintech",
    "identity-verification",
    "account-data"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/TrueLayerApi.credentials.js",
      "dist/credentials/TrueLayerOAuth.credentials.js"
    ],
    "nodes": [
      "dist/nodes/TrueLayer/TrueLayer.node.js",
      "dist/nodes/TrueLayer/TrueLayerTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "crypto-js": "^4.2.0",
    "jose": "^5.2.2",
    "uuid": "^9.0.1"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}